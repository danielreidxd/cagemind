# Frontend Environment Variables
# Copia este archivo a .env.local y actualiza los valores

# Supabase (para autenticación directa desde el frontend)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# API Backend URL (requerido para producción)
# En Railway: https://tu-app.up.railway.app
# En Render: https://tu-app.onrender.com
# En desarrollo local: puedes omitirlo o usar http://localhost:8000
VITE_API_BASE_URL=https://tu-api.up.railway.app
